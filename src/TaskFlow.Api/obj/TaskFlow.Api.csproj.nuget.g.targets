<?xml version="1.0" encoding="utf-8" standalone="no"?>
<Project ToolsVersion="14.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ImportGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <Import Project="$(NuGetPackageRoot)\yarp.reverseproxy\2.3.0\buildTransitive\net8.0\Yarp.ReverseProxy.targets" Condition="Exists('$(NuGetPackageRoot)\yarp.reverseproxy\2.3.0\buildTransitive\net8.0\Yarp.ReverseProxy.targets')" />
    <Import Project="$(NuGetPackageRoot)\microsoft.aspnetcore.openapi\10.0.8\build\Microsoft.AspNetCore.OpenApi.targets" Condition="Exists('$(NuGetPackageRoot)\microsoft.aspnetcore.openapi\10.0.8\build\Microsoft.AspNetCore.OpenApi.targets')" />
    <Import Project="$(NuGetPackageRoot)\hotchocolate.data\16.0.9\build\HotChocolate.Data.targets" Condition="Exists('$(NuGetPackageRoot)\hotchocolate.data\16.0.9\build\HotChocolate.Data.targets')" />
    <Import Project="$(NuGetPackageRoot)\hotchocolate.aspnetcore\16.0.9\build\HotChocolate.AspNetCore.targets" Condition="Exists('$(NuGetPackageRoot)\hotchocolate.aspnetcore\16.0.9\build\HotChocolate.AspNetCore.targets')" />
  </ImportGroup>
</Project>